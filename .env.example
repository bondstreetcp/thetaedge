# Google Gemini API Key (required for AI research)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Finnhub API Key (free — for real-time news, earnings calendar, analyst ratings)
# Get yours at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Upstash Redis (free tier — persistent cache, highly recommended)
# Get yours at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx_your_token_here
